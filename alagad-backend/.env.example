# Example environment variables for local development
NODE_ENV=development
PORT=5000

# Mongo
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>

# Auth
JWT_SECRET=change_me

# OpenAI
OPENAI_API_KEY=sk-...  # do NOT commit real keys
# Optional: override model (defaults to gpt-4o)
OPENAI_MODEL=gpt-4o

# Retrieval index synchronization
REINDEX_ON_STARTUP=true
# 0 disables periodic full reindex; set milliseconds for periodic bulk sync
REINDEX_INTERVAL_MS=0
