# Example environment variables for local development
REACT_APP_API_URL=http://localhost:3001/api
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# When true, login controls are hidden on the Guest View (root)
REACT_APP_HIDE_GUEST_LOGIN=false
# If you run admin on a separate dev server, set its origin here (no trailing slash recommended)
REACT_APP_ADMIN_URL=http://localhost:3002
REACT_APP_SUPERADMIN_URL=http://localhost:3003