{
  "name": "alagad-frontend",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://localhost:3001",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@mapbox/mapbox-gl-draw": "^1.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@turf/turf": "^7.3.4",
    "framer-motion": "^12.34.3",
    "geojson-path-finder": "^2.1.0",
    "mapbox-gl": "^3.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "react-map-gl": "^7.1.6",
    "react-router-dom": "^7.13.0",
    "react-scripts": "5.0.1",
    "react-speech-recognition": "^4.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "set \"HOST=0.0.0.0\"&& react-scripts start",
    "start:https": "set \"HOST=0.0.0.0\"&& set \"HTTPS=true\"&& react-scripts start",
    "start:guest": "set \"HOST=0.0.0.0\"&& set \"PORT=3000\"&& set \"REACT_APP_MODE=guest\"&& set \"REACT_APP_HIDE_GUEST_LOGIN=true\"&& react-scripts start",
    "start:guest:ngrok": "set \"HOST=0.0.0.0\"&& set \"PORT=3000\"&& set \"DANGEROUSLY_DISABLE_HOST_CHECK=true\"&& set \"WDS_SOCKET_PORT=443\"&& set \"REACT_APP_MODE=guest\"&& set \"REACT_APP_HIDE_GUEST_LOGIN=true\"&& react-scripts start",
    "start:guest:https": "set \"HOST=0.0.0.0\"&& set \"HTTPS=true\"&& set \"PORT=3000\"&& set \"REACT_APP_MODE=guest\"&& set \"REACT_APP_HIDE_GUEST_LOGIN=true\"&& react-scripts start",
    "start:admin": "set \"HOST=0.0.0.0\"&& set \"PORT=3001\"&& set \"REACT_APP_MODE=admin\"&& set \"REACT_APP_HIDE_GUEST_LOGIN=false\"&& react-scripts start",
    "start:superadmin": "set \"HOST=0.0.0.0\"&& set \"PORT=3003\"&& set \"REACT_APP_HIDE_GUEST_LOGIN=false\"&& react-scripts start",
    "build": "react-scripts build",
    "build:guest": "set \"REACT_APP_MODE=guest\"&& set \"REACT_APP_HIDE_GUEST_LOGIN=true\"&& react-scripts build",
    "build:admin": "set \"REACT_APP_MODE=admin\"&& react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  }
}
